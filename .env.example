# Supabase — get these from your Supabase project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — email sending (free tier: 3k/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL="FreeHalalMeal.com <vouchers@freehalalmeal.com>"

# Public site URL (used in voucher emails and PDF links)
NEXT_PUBLIC_SITE_URL=https://freehalalmeal.com

# Admin emails — comma-separated list of emails granted /admin access
ADMIN_EMAILS=alaltoum@gmail.com
